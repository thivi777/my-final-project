// HeroSection.module.scss
// Warm cream 2025 wellness hero with floating phone mockup

$accent:     #c4895a;
$accent-d:   #9b6840;
$brown-dark: #1a1208;
$brown-mid:  #4a3820;
$brown-soft: #8a7055;
$cream:      #faf8f4;
$cream-mid:  #f0ebe0;
$cream-deep: #e8dfd0;
$font-d:     'Plus Jakarta Sans', system-ui, sans-serif;

@keyframes fadeUp   { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
@keyframes fadeRight{ from{opacity:0;transform:translateX(32px)} to{opacity:1;transform:translateX(0)} }
@keyframes float    { 0%,100%{transform:translateY(0) rotate(1deg)} 50%{transform:translateY(-14px) rotate(-1deg)} }
@keyframes floatA   { 0%,100%{transform:translateY(0) rotate(-2deg)} 50%{transform:translateY(-9px) rotate(1.5deg)} }
@keyframes floatB   { 0%,100%{transform:translateY(0) rotate(2deg)} 50%{transform:translateY(-11px) rotate(-1.5deg)} }
@keyframes pulseDot { 0%,100%{box-shadow:0 0 0 3px rgba(196,137,90,.22)} 50%{box-shadow:0 0 0 7px rgba(196,137,90,.07)} }

// ── Root ──────────────────────────────────────────────
.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(155deg, $cream 0%, $cream-mid 45%, $cream-deep 100%);
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: clamp(2rem, 4vw, 5rem);
  padding: clamp(4rem,8vh,7rem) clamp(2rem,6vw,6rem);
  font-family: $font-d;
  isolation: isolate;
}

// Blobs
.blob {
  position: absolute; border-radius: 50%;
  pointer-events: none; filter: blur(72px); opacity: 0.5; z-index: 0;
}
.blob1 { width:500px; height:500px; background:#d4c5a9; top:-130px; right:-100px; }
.blob2 { width:340px; height:340px; background:#c9b99a; bottom:-80px; left:28%; }
.blob3 { width:220px; height:220px; background:#e8d5b8; top:42%;   left:-60px; }

// ── Left ──────────────────────────────────────────────
.left {
  position: relative; z-index: 2;
  display: flex; flex-direction: column;
  gap: clamp(16px,2.5vh,26px);
  opacity: 0;
}
.leftVisible { animation: fadeUp .8s cubic-bezier(.16,1,.3,1) .1s both; }

.badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,.72);
  border: 1px solid rgba(180,155,115,.3);
  backdrop-filter: blur(8px);
  color: #7a5c38; font-size: 11px; font-weight: 600;
  letter-spacing: .04em; padding: 6px 14px;
  border-radius: 999px; width: fit-content;
}

.badgeDot {
  width:6px; height:6px; border-radius:50%;
  background:$accent; flex-shrink:0;
  animation: pulseDot 2s ease-in-out infinite;
}

.title {
  margin: 0;
  font-size: clamp(2rem,4.5vw,3.4rem);
  font-weight: 800; line-height: 1.07;
  color: $brown-dark; letter-spacing: -.03em; max-width: 13ch;
}

.titleAccent {
  font-style: normal;
  background: linear-gradient(120deg,$accent 0%,$accent-d 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

.sub {
  margin: 0;
  font-size: clamp(.88rem,1.3vw,1rem);
  line-height: 1.72; color: #6b5840; max-width: 40ch;
}

.ctas { display:flex; gap:12px; flex-wrap:wrap; align-items:center; }

.btnMain {
  display: inline-flex; align-items: center; gap: 8px;
  height: clamp(46px,5.5vh,54px);
  background: $brown-dark; color: #f8f4ee;
  padding: 0 clamp(1.4rem,2.5vw,2rem); border-radius: 999px;
  font-family: $font-d; font-size: clamp(.85rem,1.1vw,.95rem);
  font-weight: 600; text-decoration: none; border: none; cursor: pointer;
  box-shadow: 0 4px 22px rgba(26,18,8,.22);
  transition: all .22s cubic-bezier(.34,1.56,.64,1);
  &:hover { transform:translateY(-2px) scale(1.03); box-shadow:0 8px 30px rgba(26,18,8,.3); }
  &:active { transform:scale(.98); }
}

.btnSec {
  display: inline-flex; align-items: center; gap: 6px;
  height: clamp(46px,5.5vh,54px);
  background: transparent; color: $brown-mid;
  padding: 0 clamp(1.2rem,2vw,1.6rem); border-radius: 999px;
  font-family: $font-d; font-size: clamp(.85rem,1.1vw,.95rem);
  font-weight: 500; text-decoration: none;
  border: 1.5px solid rgba(100,75,45,.22); cursor: pointer;
  transition: all .2s;
  &:hover { background:rgba(100,75,45,.07); }
}

.proof { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
.avatars { display:flex; }
.av {
  width:28px; height:28px; border-radius:50%;
  border:2px solid $cream; margin-left:-8px;
  font-size:10px; font-weight:700;
  display:flex; align-items:center; justify-content:center; color:#fff;
  &:first-child { margin-left:0; }
}
.av1{background:$accent;} .av2{background:$accent-d;} .av3{background:#7a5230;} .av4{background:#5c3d22;}

.proofText {
  font-size:11.5px; color:$brown-soft; font-weight:500;
  strong { color:$brown-dark; font-weight:700; }
}

.statRow { display:flex; gap:10px; flex-wrap:wrap; }
.statPill {
  display:flex; flex-direction:column; gap:2px;
  background:rgba(255,255,255,.6);
  border:1px solid rgba(180,155,115,.22);
  backdrop-filter:blur(6px);
  padding:8px 14px; border-radius:12px;
}
.statValue { font-size:14px; font-weight:800; color:$brown-dark; line-height:1; }
.statLabel { font-size:10px; color:$brown-soft; font-weight:500; }

// ── Right ─────────────────────────────────────────────
.right {
  position: relative; z-index: 2;
  display: flex; justify-content: center; align-items: center;
  opacity: 0;
}
.rightVisible { animation: fadeRight .9s cubic-bezier(.16,1,.3,1) .25s both; }

// Image Grid / Masonry
.imageGrid {
  position: relative;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  width: 100%;
  max-width: 600px;
  perspective: 1000px;
}

.heroImage {
  width: 100%;
  border-radius: 24px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  border: 1px solid rgba(255,255,255,0.3);
  
  &:hover {
    transform: translateY(-10px) rotateX(2deg) rotateY(-2deg);
  }
}

.imgLarge {
  grid-row: span 2;
  height: 100%;
  object-fit: cover;
  animation: float 6s ease-in-out infinite;
}

.imgSmall {
  height: 200px;
  object-fit: cover;
  animation: floatA 5s ease-in-out infinite;
}

.imgMed {
  height: 280px;
  object-fit: cover;
  animation: floatB 7s ease-in-out infinite;
}

// ── Responsive ────────────────────────────────────────
@media(max-width:900px) {
  .hero { grid-template-columns:1fr; text-align:center; padding:4rem 2rem 3rem; }
  .title,.sub { max-width:100%; }
  .ctas,.proof,.statRow { justify-content:center; }
  .right { margin-top:2rem; }
  .floatLeft  { left:-20px; top:5%; }
  .floatRight { right:-20px; bottom:5%; }
}
@media(max-width:480px) {
  .floatLeft,.floatRight { display:none; }
  .ctas { flex-direction:column; }
  .btnMain,.btnSec { width:100%; justify-content:center; }
}
