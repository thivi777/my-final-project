.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  transition: all 0.3s ease;
  padding: 1rem 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;

  &.scrolled {
    background-color: rgba(255, 255, 255, 0.95); // your card color
    backdrop-filter: blur(10px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
}

.nav-links {
  display: flex;
  gap: 2rem;

  a {
    font-size: 0.875rem;
    font-weight: 500;
    color: #555; // muted-foreground equivalent
    text-decoration: none;
    transition: color 0.2s;

    &:hover {
      color: #111; // foreground equivalent
    }
  }
}

.logo {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-size: 1.4rem;
  font-weight: 800;
  text-decoration: none;
  color: #1a1208;
  letter-spacing: -0.02em;
}

.logoWrapper {
  width: 40px;
  height: 40px;
  overflow: hidden;
  border-radius: 10px;
  position: relative;
}

.logoImage {
  position: absolute;
  top: 0;
  left: 0;
  width: 300%; // 3 logos in one image
  height: 100%;
  object-fit: cover;
  object-position: left; // Shows the first (teal) logo
}

.mobile-menu {
  display: none;
  flex-direction: column;
  padding: 1rem 0;
  gap: 1rem;
  border-top: 1px solid #ddd;

  a {
    color: #555;
    font-weight: 500;

    &:hover {
      color: #111;
    }
  }

  .button {
    width: 100%;
  }
}

.mobile-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
}

@media (max-width: 768px) {
  .nav-links {
    display: none;
  }

  .mobile-toggle {
    display: block;
  }

  .mobile-menu {
    display: flex;
  }
}