@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 30 20% 98%; // Warm Cream/Off-white
    --foreground: 0 0% 16%; // Charcoal

    --card: 0 0% 100%;
    --card-foreground: 0 0% 16%;

    --primary: 154 11% 40%; // Muted Sage
    --primary-foreground: 0 0% 98%;

    --secondary: 154 11% 20%; // Deep Sage/Charcoal
    --secondary-foreground: 0 0% 98%;

    --muted: 154 5% 60%;
    --muted-foreground: 154 5% 30%;

    --accent: 154 11% 95%; // Soft Sage Tint
    --accent-foreground: 154 11% 30%;

    --border: 154 5% 90%;
    --input: 154 5% 90%;
    --ring: 154 11% 40%;

    --radius: 1.25rem; // Softer, more organic corners

    --font-serif: 'Cormorant Garamond', serif;
    --font-sans: 'DM Sans', sans-serif;
  }

  .dark {
    --background: 0 0% 12%;
    --foreground: 30 20% 98%;
    --card: 0 0% 16%;
    --card-foreground: 30 20% 98%;
    --primary: 154 11% 60%;
    --primary-foreground: 0 0% 12%;
    --border: 0 0% 20%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground;
    font-family: var(--font-sans);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-serif);
    font-weight: 500;
  }
}
