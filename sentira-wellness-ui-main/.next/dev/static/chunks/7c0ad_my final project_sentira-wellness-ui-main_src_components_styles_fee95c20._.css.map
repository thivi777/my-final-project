$bg-page: #dfdfdf;
$overlay-color: rgba(20, 20, 20, 0.28);
$kicker-bg: #10b981; // Updated to primary green from Sentira
$text-white: #fff;
$muted-white: rgba(255,255,255,0.9);
$dot-bg: rgba(255,255,255,0.12);
$peel-border: rgba(255,255,255,0.12);

.hero {
  position: relative;
  width: 100%;
  min-height: 520px;
  background: $bg-page;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: stretch;

  .bgWrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;

    .bgVideo, .bgImage {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      min-width: 100%;
      min-height: 100%;
      width: auto;
      height: auto;
      object-fit: cover;
      filter: saturate(0.95) contrast(0.95);
    }
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: $overlay-color;
    z-index: 1;
  }

  .content {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 32px;
    padding: 48px;
    align-items: stretch;

    .leftColumn {
      width: 36%;
      display: flex;
      gap: 16px;
      align-items: flex-start;
      color: $text-white;
      position: relative;

      .sideNumbers {
        display: flex;
        flex-direction: column;
        gap: 18px;
        align-items: center;
        padding-top: 8px;

        .dotRow {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 36px;
          height: 36px;

          .dot {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: $dot-bg;
            color: $muted-white;
            font-weight: 700;
            font-size: 14px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.25);
          }
        }
      }

      .textBlock {
        max-width: 520px;

        .kicker {
          display: inline-block;
          background: $kicker-bg;
          color: #fff;
          padding: 6px 10px;
          border-radius: 4px;
          font-weight: 700;
          margin-bottom: 12px;
          font-size: 13px;
        }

        .title {
          margin: 0 0 12px 0;
          font-size: 32px;
          line-height: 1.05;
          color: $text-white;
          text-shadow: 0 6px 18px rgba(0,0,0,0.45);
          font-family: 'Playfair Display', serif;
        }

        .subtitle {
          margin: 0 0 18px 0;
          color: rgba(255,255,255,0.9);
          font-size: 15px;
          line-height: 1.5;
          font-family: 'Inter', sans-serif;
        }

        .cta {
          background: rgba(255,255,255,0.12);
          border: 1px solid rgba(255,255,255,0.14);
          color: white;
          padding: 10px 14px;
          border-radius: 6px;
          cursor: pointer;
          transition: all 0.3s ease;
          
          &:hover {
            background: rgba(255,255,255,0.2);
            transform: translateY(-2px);
          }
        }
      }
    }

    .visualWrap {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding-right: 36px;

      .peel {
        width: 62%;
        max-width: 780px;
        aspect-ratio: 16/9;
        position: relative;
        transform: rotate(-11deg);
        transform-origin: center;
        box-shadow: 0 18px 50px rgba(0,0,0,0.45);
        border-radius: 6px;
        overflow: visible;

        .peelVideo, .peelImage {
          position: absolute;
          inset: 0;
          width: 110%;
          height: 110%;
          left: -5%;
          top: -5%;
          object-fit: cover;
          border-radius: 6px;
          filter: saturate(1.05) contrast(1.02) brightness(1.02);
          clip-path: inset(0 round 6px);
        }

        .peelBorder {
          pointer-events: none;
          position: absolute;
          inset: 0;
          border-radius: 6px;
          border: 4px solid $peel-border;
          box-shadow: 0 6px 20px rgba(0,0,0,0.45) inset;
        }

        .peelCurl {
          pointer-events: none;
          position: absolute;
          width: 90px;
          height: 90px;
          right: -18px;
          top: -18px;
          transform: rotate(-28deg);
          background: linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0.02));
          box-shadow: -6px 8px 18px rgba(0,0,0,0.35);
          border-radius: 8px;
          filter: blur(1px);
        }
      }
    }
  }

  .caption {
    width: 100%;
    z-index: 3;
    display: flex;
    justify-content: center;
    padding: 10px 16px;

    .captionInner {
      background: rgba(255,255,255,0.95);
      color: #222;
      padding: 8px 14px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 14px;
    }
  }

  // responsive
  @media (max-width: 980px) {
    .content {
      flex-direction: column;
      padding: 28px;
      gap: 20px;

      .leftColumn {
        width: 100%;
        flex-direction: row;
        align-items: flex-start;
        gap: 14px;
      }

      .visualWrap {
        order: -1;
        width: 100%;
        padding-right: 0;
      }

      .peel {
        width: 100%;
        max-width: none;
        transform: rotate(-6deg);

        .peelVideo, .peelImage { /* reduce zoom on small screens */
          width: 105%;
          height: 105%;
          left: -2.5%;
          top: -2.5%;
        }
      }

      .title { font-size: 22px; }
    }
  }
}
