{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/insights/layout,_N_T_/app/insights/page,_N_T_/app/insights"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/insights/__PAGE__",
    "/app/insights",
    "/app",
    "/_index",
    "/_head"
  ]
}