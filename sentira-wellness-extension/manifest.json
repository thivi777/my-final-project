{
  "manifest_version": 3,
  "name": "Sentira Wellness Assistant",
  "version": "1.0.0",
  "description": "Your digital companion for emotional wellness, Grammarly-style.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "host_permissions": ["http://localhost:5000/*"]
}
