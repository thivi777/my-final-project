{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/sentira-wellness-ui-main/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "runtime": "vercel-node@latest",
      "includeFiles": "emotional-wellness-backend/**"
    }
  }
}
