{
  "name": "sentira-wellness",
  "version": "1.0.0",
  "description": "Sentira Wellness Full Stack Application",
  "workspaces": [
    "sentira-wellness-ui-main",
    "emotional-wellness-backend"
  ],
  "scripts": {
    "dev:ui": "npm run dev -w sentira-wellness-ui-main",
    "dev:api": "npm run dev -w emotional-wellness-backend",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "build": "npm run build -w sentira-wellness-ui-main"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
